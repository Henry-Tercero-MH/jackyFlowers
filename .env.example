# Google Apps Script — Backend
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_APPS_SCRIPT_ID/exec

# NextAuth Configuration (genera con: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-secret-here
